# =============================================================================
# PortIQ — Environment variables
# Copy to .env in project root:  cp .env.example .env
# Then fill in YOUR_DB_PASSWORD and keys marked below.
# =============================================================================

# --- Server ---
# Local dev only — Railway injects PORT automatically (usually 8080). Do NOT set PORT on Railway.
# If you copied PORT=3000 to Railway, delete it — that causes 502 (app on 3000, proxy on 8080).
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://port-iq-rho.vercel.app
PORTFOLIO_USER_ID=00000000-0000-4000-8000-000000000001

# --- Supabase (backend) — REQUIRED ---
# Use Session pooler (NOT "Direct connection") — Railway cannot reach Supabase IPv6 direct hosts.
# Supabase → Project Settings → Database → Connection string → URI → Session pooler
# Host must look like: aws-0-<region>.pooler.supabase.com:5432
# Replace YOUR_DB_PASSWORD with your database password (NOT the API secret key)
DATABASE_URL=postgresql://postgres.jbifulniginhadhwfusm:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Server-only Supabase admin (optional — not used by current backend; for future server features)
# Get from: Project Settings → API → Secret keys — NEVER prefix with VITE_, never commit real value
SUPABASE_URL=https://jbifulniginhadhwfusm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# --- Upstash Redis (cache + rate limits) — no SQL/schema needed ---
# Option A: REST vars (server auto-builds rediss:// TCP URL for ioredis/BullMQ)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Option B: explicit TCP URL
# REDIS_URL=rediss://default:token@your-database.upstash.io:6379
# Option C: local Redis
# REDIS_URL=redis://localhost:6379

# --- Market Data (Layer 1) — server-side only ---
# Production: fmp (recommended). Local dev: yahoo (no key required).
MARKET_DATA_PROVIDER=fmp
MARKET_DATA_CACHE_TTL_MS=300000
MARKET_DATA_STALE_TTL_MS=86400000
YAHOO_FETCH_DELAY_MS=120

# NSE uses .NS suffix, BSE uses .BO (e.g. RELIANCE.NS not RELIANCE.NSE)
FMP_API_KEY=your_fmp_api_key_here
# TWELVE_DATA_API_KEY=
# ALPHA_VANTAGE_API_KEY=

# --- OpenRouter AI (Layer 3) — set OPENROUTER_API_KEY to enable live LLM phrasing ---
# Default: openrouter/free (auto-routes to available $0 models)
# Specific free models: google/gemma-4-26b-a4b-it:free | google/gemma-4-31b-it:free | meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_RATE_LIMIT_PER_MINUTE=30
OPENROUTER_RATE_LIMIT_PER_DAY=500
OPENROUTER_429_RETRIES=2
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_TITLE=PortIQ
OPENROUTER_TIMEOUT_MS=25000
OPENROUTER_TEMPERATURE=0.2

ANALYZE_CACHE_TTL_MS=60000
STRESS_CACHE_TTL_MS=60000
STOCK_ANALYZER_CACHE_TTL_MS=120000
ANALYZER_COMPUTE_CACHE_TTL_MS=120000
FUNDAMENTALS_CACHE_TTL_MS=120000
ALPHAEDGE_CACHE_TTL_MS=60000

# --- BullMQ worker (optional: npm run worker in server/) ---
# CONVICTION_DECAY_CRON=0 6 * * *

# --- Frontend (Vite — safe to expose in browser) ---
# REQUIRED on Vercel — must include https:// or browser POSTs to vercel.app (405).
VITE_API_URL=https://portiq-production.up.railway.app
VITE_SUPABASE_URL=https://jbifulniginhadhwfusm.supabase.co
# Get from: Project Settings → API → Publishable key (NOT the secret key)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpiaWZ1bG5pZ2luaGFkaHdmdXNtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3NTE0OTMsImV4cCI6MjA5ODMyNzQ5M30.HuN3jVHdPlTiw6fjTAfgHVjdNtoiWLpxnkgIV8ZqaBc
